{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "moe.kinnnine.ocd2kki",
  "version": "d4e3b6a",
  "applicationName": "ocd2kki",
  "author": "kinnnine",
  "description": "Unofficial desktop client of Yume 2kki on ynoproject.net (Yume Nikki Online Project)",
  "copyright": "MIT License © kinnnine 2026.",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/resources/",
  "url": "https://ynoproject.net/2kki/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "none",
  "exportAuthInfo": false,
  "logging": {
    "enabled": false,
    "writeToLogFile": false
  },
  "nativeAllowList": [
    "app.quit",
    "window.setTitle",
    "window.setSize",
    "window.getSize",
    "comptuer.getDisplays"
  ],
  "nativeBlockList": [
    "filesystem.*",
    "os.*"
  ],
  "modes": {
    "window": {
      "title": "ocd2kki",
      "width": 640,
      "height": 480,
      "minWidth": 640,
      "minHeight": 480,
      "center": true,
      "fullScreen": false,
      "alwaysOnTop": false,
      "icon": "/resources/icons/urotsuki.png",
      "enableInspector": false,
      "borderless": false,
      "maximize": false,
      "hidden": false,
      "resizable": false,
      "useLogicalPixels": true,
      "useSavedState": true,
      "exitProcessOnClose": true,
      "injectGlobals": true,
      "injectClientLibrary": true,
      "injectScript": "/resources/js/ocd.js",
      "dataLocation": "system",
      "storageLocation": "system"
    },
    "browser": {
      "nativeBlockList": [
        "filesystem.*"
      ]
    },
    "chrome": {
      "width": 817,
      "height": 647,
      "nativeBlockList": [
        "filesystem.*",
        "os.*"
      ]
    }
  },
  "cli": {
    "binaryName": "ocd2kki",
    "resourcesPath": "/resources/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/resources/js/neutralino.js",
    "binaryVersion": "6.5.0",
    "clientVersion": "6.5.0"
  }
}